# Manda TODOS los pedidos de /api/... al router (index.php).
# Esto permite URLs lindas como /api/causas en vez de /api/index.php?...
RewriteEngine On
RewriteBase /api/

# Si el archivo o carpeta existe de verdad, dejarlo pasar (ej: imágenes).
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Todo lo demás lo maneja index.php
RewriteRule ^ index.php [QSA,L]

# No permitir que se descarguen archivos sensibles
<FilesMatch "\.(sql|md|example\.php)$">
  Require all denied
</FilesMatch>
<Files "config.php">
  Require all denied
</Files>
